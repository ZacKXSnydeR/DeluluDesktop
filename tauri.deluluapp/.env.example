# Delulu Frontend - Environment Variables Template
# Copy this file to .env and fill in your actual keys.

# TMDb API (Required for metadata)
# Get your API key from https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_READ_TOKEN=your_tmdb_read_token_here

# Firebase Configuration (Required for Authentication)
# Get these from your Firebase Console -> Project Settings -> Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Optional: Remote Sync API (Leave empty if using local-only mode)
VITE_DB_API_URL=
VITE_API_KEY=
