{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Delulu",
  "version": "1.0.0",
  "identifier": "com.delulu.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "features": ["devtools"]
  },
  "app": {
    "windows": [
      {
        "title": "Delulu",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://image.tmdb.org https://img.youtube.com https://*.googleusercontent.com http://127.0.0.1:* data: blob:; media-src 'self' blob: https: http://127.0.0.1:*; connect-src 'self' https: http://127.0.0.1:* wss://*.firebaseio.com; frame-src https://accounts.google.com https://*.firebaseapp.com",
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "resources/local-extractor",
      "resources/runtime/node.exe"
    ],
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "nsis-hooks.nsi"
      }
    }
  }
}