# Backend Server
PORT=3001

# Backend API key (used by protected routes)
API_KEY=change_me_strong_random_key

# Firebase Admin SDK
VITE_FIREBASE_PROJECT_ID=your_project_id

# Preferred: JSON service account (single-line escaped JSON)
FIREBASE_SERVICE_ACCOUNT_KEY=your_service_account_json

# Optional alternative to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
